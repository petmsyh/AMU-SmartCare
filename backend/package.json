{
  "name": "amu-smartcare-backend",
  "version": "1.0.0",
  "description": "AMU SmartCare Patient-Doctor Connection Platform Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "npm run db:setup && node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:retry": "sh -c 'for i in 1 2 3 4 5 6; do prisma migrate deploy && exit 0; echo \"Database not reachable yet, retrying ($i/6)...\"; sleep 5; done; exit 1'",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:setup": "npm run db:migrate:deploy:retry && npm run db:seed",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
